generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  role          String // donor, ngo, volunteer, admin
  phone_number  String?  @unique
  email         String?  @unique
  password_hash String
  name_or_org   String
  lat           Float?
  lng           Float?
  address       String?
  is_verified   Boolean  @default(false)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  donations        Donation[]      @relation("DonorToDonations")
  ngo_requests     NgoRequest[]    @relation("NgoToRequests")
  volunteer_tasks  VolunteerTask[] @relation("VolunteerToTasks")
  notifications    Notification[]
  given_ratings    Rating[]        @relation("RatingsGiven")
  received_ratings Rating[]        @relation("RatingsReceived")
}

model Donation {
  id          String    @id @default(uuid())
  donor_id    String
  food_type   String
  quantity    Int
  cooked_time DateTime?
  expiry_time DateTime
  photo_url   String?
  pickup_lat  Float
  pickup_lng  Float
  status      String    @default("pending") // pending, accepted, assigned, collected, completed, cancelled
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  donor           User            @relation("DonorToDonations", fields: [donor_id], references: [id])
  requests        NgoRequest[]
  volunteer_tasks VolunteerTask[]
  ratings         Rating[]
}

model NgoRequest {
  id                 String   @id @default(uuid())
  donation_id        String
  ngo_id             String
  status             String   @default("requested") // requested, approved, declined
  needs_volunteer    Boolean  @default(false)
  requested_quantity Int
  created_at         DateTime @default(now())

  donation Donation @relation(fields: [donation_id], references: [id])
  ngo      User     @relation("NgoToRequests", fields: [ngo_id], references: [id])
}

model VolunteerTask {
  id                    String    @id @default(uuid())
  donation_id           String
  volunteer_id          String
  status                String    @default("assigned") // assigned, en_route_donor, picked_up, en_route_ngo, delivered
  estimated_pickup_time DateTime?
  actual_pickup_time    DateTime?
  actual_delivery_time  DateTime?
  delivery_photo_proof  String?
  created_at            DateTime  @default(now())

  donation  Donation @relation(fields: [donation_id], references: [id])
  volunteer User     @relation("VolunteerToTasks", fields: [volunteer_id], references: [id])
}

model Notification {
  id         String   @id @default(uuid())
  user_id    String
  type       String
  title      String
  message    String
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])
}

model Rating {
  id           String   @id @default(uuid())
  from_user_id String
  to_user_id   String
  donation_id  String
  score        Int
  feedback     String?
  created_at   DateTime @default(now())

  from_user User     @relation("RatingsGiven", fields: [from_user_id], references: [id])
  to_user   User     @relation("RatingsReceived", fields: [to_user_id], references: [id])
  donation  Donation @relation(fields: [donation_id], references: [id])
}

model MlPrediction {
  id              String   @id @default(uuid())
  entity_id       String // donor or ngo ID
  prediction_type String // surplus, demand
  predicted_value Float
  target_date     DateTime
  generated_at    DateTime @default(now())
}
